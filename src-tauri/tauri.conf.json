{
  "build": {
    "distDir": "../src",
    "devPath": "../src"
  },
  "package": {
    "productName": "GroqChatLite",
    "version": "1.0.0"
  },
  "tauri": {
    "allowlist": {
      "all": true
    },
    "bundle": {
      "active": true,
      "identifier": "com.mikakrul.groqchat",
      "icon": [
        "icon/32x32.png",
        "icon/32x32@2x.png",
        "icon/128x128.png",
        "icon/128x128@2x.png",
        "icon/icon.ico",
        "icon/icon.png",
        "icon/1024x1024.png",
        "icon/256x256.png",
        "icon/512x512.png"
      ],
      "targets": "all"
    },
    "windows": [
      {
        "fullscreen": false,
        "height": 700,
        "resizable": true,
        "title": "GroqChat Lite",
        "width": 900
      }
    ]
  }
}
